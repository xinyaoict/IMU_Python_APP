<!-- circle_background.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- Solid color for the circle background -->
    <solid android:color="@color/lightGreen" />

    <!-- Stroke (border) for the circle -->
    <stroke
        android:width="2dp"
        android:color="@color/grayDarkBlue" /> <!-- Color of the border -->

</shape>
